{
  "name": "mini-tools",
  "version": "0.0.0",
  "private": true,
  "description": "Da Excel a Software — monorepo di mini-tool desktop per PMI italiane",
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8",
    "prettier": "^3.4.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
