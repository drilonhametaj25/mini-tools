{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Riconciliazione Bancaria",
  "version": "0.1.0",
  "identifier": "it.drilonhametaj.riconciliazione-bancaria",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1426",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "Riconciliazione Bancaria — Da Excel a Software", "width": 1400, "height": 860, "minWidth": 1000, "minHeight": 600, "theme": "Dark" }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png","icons/128x128.png","icons/128x128@2x.png","icons/icon.icns","icons/icon.ico"],
    "category": "Productivity",
    "copyright": "© 2026 Drilon Hametaj — drilonhametaj.it",
    "shortDescription": "Quadra estratto conto con fatture in pochi click"
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://drilonhametaj.it/api/updates/riconciliazione-bancaria/{{target}}-{{arch}}"],
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBKEY",
      "dialog": true
    }
  }
}
