{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permessi base per AI Aziendale Locale",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "dialog:default",
    "fs:default",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "http:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "updater:default"
  ]
}
