# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# JWT keypair RS256 (PEM, multiline → \\n nelle env)
LICENSING_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
LICENSING_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# JWT durata
LICENSING_JWT_TTL_DAYS=14

# Admin (Supabase Auth: lista email separate da virgola)
LICENSING_ADMIN_EMAILS=drilonhametaj25@gmail.com

# Updates manifest
UPDATES_BASE_URL=https://updates.drilonhametaj.it
UPDATES_SIGNING_PUBKEY=
